{
  "name": "api-hub-backend-server",
  "version": "1.0.0",
  "description": "Backend REST API server for managing and serving API Hub resources and endpoints",
  "license": "ISC",
  "author": "Maksym Zabrodin",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "type-check": "tsc --noEmit",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "argon2": "0.44.0",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "9.0.3",
    "nodemailer": "8.0.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.6.0",
    "@types/nodemailer": "8.0.0",
    "prisma": "7.7.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
